# === kicad-hwdesign MCP Server 설정 ===
# AI API 키 불필요 — Claude Desktop / ChatGPT 구독이 AI 역할을 수행합니다.
# LCSC/JLCPCB 부품 검색도 키 없이 동작합니다.

# 부품 검색 API (선택 — 설정하면 search_component_multi에서 사용)
# Mouser: https://www.mouser.com/api-search/ 에서 발급
MOUSER_API_KEY=
# DigiKey: https://developer.digikey.com/ 에서 OAuth2 클라이언트 생성
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# 로그 레벨
HWDESIGN_LOG_LEVEL=INFO
